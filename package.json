{
  "name": "catalog-api-firestore",
  "version": "1.1.0",
  "description": "Simple Catalog API on Firestore for Cloud Run",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck:domain": "tsc -p tsconfig.domain.json --noEmit",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx watch server.ts",
    "clean": "rimraf dist",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.10.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^29.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}